# --- Plain local Postgres (used when PGHOST is not set) ---
# DATABASE_URL="postgresql://user:password@localhost:5432/caspers_kitchen"

# --- Lakebase ---
# When PGHOST is set, the app connects to Lakebase instead of DATABASE_URL.
#
# Auth (pick one):
#   Local dev -- CLI token, refresh with: bun run lakebase:token
#     DATABRICKS_TOKEN="<from databricks auth token>"
#     PGUSER="you@databricks.com"
#
#   Production (Vercel) -- M2M OAuth service principal
#     DATABRICKS_CLIENT_ID="your-service-principal-client-id"
#     DATABRICKS_CLIENT_SECRET="your-service-principal-client-secret"
#
DATABRICKS_HOST="https://your-workspace.cloud.databricks.com"
LAKEBASE_ENDPOINT="projects/{project-id}/branches/{branch-id}/endpoints/{endpoint-id}"
PGHOST="your-lakebase-host.databricks.com"
PGDATABASE="databricks_postgres"
# PGPORT="5432"
# PGSSLMODE="require"

# --- Auth ---
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# --- Simulation Cron ---
CRON_SECRET="generate-with-openssl-rand-base64-32"
